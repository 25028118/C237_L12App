<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>To-Do List</title>
    <style>
        body { background-color: #f8f9fa; }
        .priority-badge-high   { background-color: #dc3545; }
        .priority-badge-medium { background-color: #ffc107; color: #000 !important; }
        .priority-badge-low    { background-color: #198754; }
        .task-done td { opacity: 0.5; text-decoration: line-through; }
        .stat-card { border-left: 4px solid; }
        .stat-card.total   { border-color: #0d6efd; }
        .stat-card.pending { border-color: #ffc107; }
        .stat-card.done    { border-color: #198754; }
        .stat-card.urgent  { border-color: #dc3545; }
    </style>
</head>
<body>

    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <h2 class="mb-4">My Tasks</h2>

        <!-- Stats row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card stat-card total p-3 text-center">
                    <div class="fs-2 fw-bold text-primary"><%= total %></div>
                    <div class="text-muted small">Total Tasks</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card stat-card pending p-3 text-center">
                    <div class="fs-2 fw-bold text-warning"><%= pending %></div>
                    <div class="text-muted small">Pending</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card stat-card done p-3 text-center">
                    <div class="fs-2 fw-bold text-success"><%= completed %></div>
                    <div class="text-muted small">Completed</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card stat-card urgent p-3 text-center">
                    <div class="fs-2 fw-bold text-danger"><%= urgent %></div>
                    <div class="text-muted small">High Priority</div>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="/add" class="btn btn-success">+ Add New Task</a>
            <form method="get" action="/" class="d-flex align-items-center gap-2">
                <label for="sort" class="mb-0 text-muted small">Sort by:</label>
                <select name="sort" id="sort" class="form-select form-select-sm" style="width:auto;">
                    <option value="deadline" <%= sort === 'deadline' ? 'selected' : '' %>>Deadline</option>
                    <option value="priority" <%= sort === 'priority' ? 'selected' : '' %>>Priority</option>
                </select>
                <button type="submit" class="btn btn-sm btn-secondary">Apply</button>
            </form>
        </div>

        <!-- Tasks table -->
        <% if (tasks.length === 0) { %>
            <div class="alert alert-info text-center">
                No tasks yet! Click <strong>+ Add New Task</strong> to get started.
            </div>
        <% } else { %>
        <div class="table-responsive">
            <table class="table table-bordered table-hover bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Task</th>
                        <th>Deadline</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% tasks.forEach((task, i) => { %>
                    <tr class="<%= task.completed ? 'task-done' : '' %>">
                        <td><%= i + 1 %></td>
                        <td><%= task.title %></td>
                        <td><%= task.deadline %></td>
                        <td>
                            <span class="badge priority-badge-<%= task.priority %>">
                                <%= task.priority.charAt(0).toUpperCase() + task.priority.slice(1) %>
                            </span>
                        </td>
                        <td>
                            <% if (task.completed) { %>
                                <span class="badge bg-success">Done</span>
                            <% } else { %>
                                <span class="badge bg-warning text-dark">Pending</span>
                            <% } %>
                        </td>
                        <td>
                            <form action="/complete/<%= task.id %>" method="post" class="d-inline">
                                <button class="btn btn-sm <%= task.completed ? 'btn-secondary' : 'btn-success' %>" type="submit">
                                    <%= task.completed ? 'Undo' : '✔ Done' %>
                                </button>
                            </form>
                            <a href="/edit/<%= task.id %>" class="btn btn-sm btn-warning">Edit</a>
                            <form action="/delete/<%= task.id %>" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this task?')">
                                <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>

</body>
</html>